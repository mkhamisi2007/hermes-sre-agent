# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# --- Telegram (required) ---
# Get a bot token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# Comma-separated list of Telegram numeric user/chat IDs allowed to interact with the assistant.
# Anyone not in this list is rejected (FR-007). Get your ID from @userinfobot.
TELEGRAM_ALLOWED_USERS=

# --- LLM (required) — local Ollama on the Docker Desktop host ---
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_MODEL_NAME=llama3.2:latest
# Ollama does not require a key; keep a placeholder so client libraries that require a non-empty key don't fail.
LLM_API_KEY=NA

# --- Kubernetes cluster (required) ---
# Path to a READ-ONLY kubeconfig (see skills/sre/cluster-watch/scripts/rbac-readonly.yaml).
# Server address must be https://kubernetes.docker.internal:6443 (not 127.0.0.1 or host.docker.internal —
# see specs/001-k8s-sre-assistant/research.md R2 for why).
KUBECONFIG_PATH=./kubeconfig/config

# --- Monitoring (optional, has a default) ---
# Cron schedule for the cluster-watch skill. Default: every 5 minutes.
MONITOR_INTERVAL="*/5 * * * *"

# --- Local storage (optional, has defaults) ---
OBSIDIAN_VAULT_PATH=./obsidian
SKILLS_PATH=./skills/sre
